# Resend API key used by the server-side contact form endpoint.
# Create one at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxx

# Email address that receives portfolio contact form submissions.
# Use an inbox you control.
RESEND_TO_EMAIL=your-email@example.com

# Verified sender address used by Resend.
# For production, verify your own domain in Resend and use something like:
# Meirhan Lotfy Portfolio <hello@yourdomain.com>
#
# For testing, Resend may allow:
# Meirhan Lotfy Portfolio <onboarding@resend.dev>
RESEND_FROM_EMAIL=Meirhan Lotfy Portfolio <onboarding@resend.dev>
